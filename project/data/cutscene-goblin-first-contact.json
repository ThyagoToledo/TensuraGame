  "beats": [
    {
      "id": "forest_threshold",
      "cameraCue": "cave_exit_to_forest_wide",
      "audioCues": ["cave_ambience_fade_out", "tempest_forest_theme_fade_in"],
      "autoDurationSeconds": 2.0,
      "lines": []
